# Copy to config/env and fill in values. Never commit config/env.

# LiteLLM (external — point to your running instance)
LITELLM_URL=http://your-litellm-host:8080
LITELLM_API_KEY=
LITELLM_MODEL=cliproxy/claude-sonnet-4-6

# IXL credentials
IXL_EMAIL=student@school.org
IXL_PASSWORD=

# Schoology credentials
SGY_EMAIL=parent@example.com
SGY_PASSWORD=
SGY_BASE_URL=https://api.schoology.com
SGY_SCHOOL_NID=

# Google Workspace (gog CLI — set up with: gog auth add EMAIL)
GOG_ACCOUNT=parent@gmail.com

# School email account for intel extraction
SCHOOL_EMAIL_ACCOUNT=parent@gmail.com

# Notification
NTFY_TOPIC=your-private-topic
DIGEST_EMAIL=parent@example.com

# GameChanger extracurricular schedule
# GC_TOKEN is the bearer token from your browser session (preferred for headless use)
# Alternatively use GC_EMAIL + GC_PASSWORD for Playwright login
GC_TOKEN=
# GC_EMAIL=jd@example.com
# GC_PASSWORD=
# GC_DEVICE_ID=
# Map team IDs to child names: "teamid:Ford,teamid2:Jack,teamid3:Penn"
# Run `gc teams --json` on the container to discover team IDs, then fill this in.
# GC_TEAM_MAP=abc123:Ford,def456:Jack,ghi789:Penn

# Paths (defaults work inside Docker — only override for local dev)
# SCHOOL_STATE_PATH=/app/state/school-state.json
# SCHOOL_DB_PATH=/app/state/school.db
# SCHOOL_FACTS_PATH=/app/state/facts.json
# SCHOOL_EMAIL_DIGEST=/app/state/email-digest.json
# SCHOOL_CALENDAR_PDF=/app/state/calendar.pdf
# SCHOOL_GC_PATH=/app/state/gc-schedule.json
